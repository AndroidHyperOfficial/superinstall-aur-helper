# Maintainer: AndroidHyperOfficial
pkgname=superinstall
pkgver=1.3
pkgrel=1
pkgdesc="A security-focused CLI package manager alternative to paru and yay"
arch=('x86_64')
url="https://github.com/AndroidHyperOfficial/superinstall-aur-helper"
license=('GPL-3.0')
depends=('pacman' 'git' 'curl' 'gnupg')
makedepends=('go')

source=("git+https://github.com/AndroidHyperOfficial/superinstall-aur-helper.git")
sha256sums=('SKIP')

build() {
    # Move into the inner directory where your Go files actually live
    cd "$srcdir/superinstall-aur-helper/superinstall"
    
    # Now this will find main.go and go.mod
    go build -o superinstall .
}

package() {
    # Match the folder path used in build()
    cd "$srcdir/superinstall-aur-helper/superinstall"
    
    install -Dm755 superinstall "$pkgdir/usr/bin/superinstall"
}